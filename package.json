{
  "name": "flutter-web-portfolio",
  "version": "1.9.0",
  "private": true,
  "description": "A JSON-driven Flutter Web portfolio template with measured navigation, accessible editorial layouts, and a dual-runtime Wasm release.",
  "scripts": {
    "portfolio:init": "node tool/init_portfolio.mjs",
    "portfolio:validate": "dart run tool/validate_portfolio.dart",
    "test:template": "node tool/test_portfolio_init.mjs",
    "test:clone": "node tool/test_template_clone.mjs",
    "build:release": "node tool/build_portfolio.mjs",
    "deploy": "node tool/deploy_portfolio.mjs",
    "test": "playwright test",
    "test:e2e": "playwright test",
    "test:e2e:prod": "playwright test --config playwright.prod.config.ts",
    "test:visual": "playwright test tests/e2e/visual.spec.ts",
    "test:visual:update": "playwright test tests/e2e/visual.spec.ts --update-snapshots",
    "sync:content": "node tool/sync_public_content.mjs",
    "verify:content": "node tool/sync_public_content.mjs --check",
    "audit:sources": "node tool/audit_public_sources.mjs",
    "audit:history": "node tool/audit_repository_history.mjs",
    "render:social-card": "node tool/render_social_card.mjs",
    "render:work-artifacts": "node tool/render_work_artifacts.mjs",
    "verify:source": "node tool/verify_dart_reachability.mjs",
    "verify:hosting": "node tool/verify_hosting_configs.mjs",
    "prepare:source": "node tool/render_social_card.mjs && node tool/write_source_manifest.mjs",
    "prepare:bundle": "node tool/prepare_web_release.mjs",
    "verify:bundle": "node tool/verify_web_build.mjs",
    "measure:runtime": "node tool/measure_web_runtime.mjs",
    "verify:runtime": "node tool/measure_web_runtime.mjs --enforce"
  },
  "keywords": [
    "flutter",
    "flutter-web",
    "webassembly",
    "skwasm",
    "playwright",
    "portfolio",
    "portfolio-template",
    "static-site",
    "firebase-hosting",
    "cloudflare-pages"
  ],
  "license": "MIT",
  "type": "commonjs",
  "homepage": "https://developeryusuf.com",
  "devDependencies": {
    "@playwright/test": "^1.59.1"
  }
}
